{
	"name": "Community Energy Orchestrator",
	"build": {
		"dockerfile": "./Dockerfile",
		"context": ".."
	},
	"containerUser": "vscode",
	"remoteUser": "vscode",
	"containerEnv": {
		"APP_ROOT": "/workspaces/${localWorkspaceFolderBasename}",
		"UV_PROJECT_ENVIRONMENT": "/workspaces/${localWorkspaceFolderBasename}/.venv"
	},
	"features": {
		"ghcr.io/devcontainers/features/docker-outside-of-docker:1": {
			"dockerDashComposeVersion": "none"
		}
	},
	"postStartCommand": "sudo chown root:docker /var/run/docker.sock 2>/dev/null && sudo chmod 660 /var/run/docker.sock 2>/dev/null || true",
	"postCreateCommand": ".devcontainer/scripts/post-create.sh"
}
